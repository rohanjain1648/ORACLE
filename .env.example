# Prophet Arena API key — get from https://prophetarena.co/developer
PA_SERVER_API_KEY=your_prophet_arena_api_key_here
PA_SERVER_URL=https://api.aiprophet.dev

# LLM provider — Claude is our primary forecaster
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Web search (Tavily recommended — free tier works)
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: second LLM for ensemble
OPENAI_API_KEY=your_openai_api_key_here

# Experiment config
# IMPORTANT: slug MUST be prefixed eval_<team-name> for official scoring
ORACLE_SLUG=eval_oracle
ORACLE_MAX_TICKS=1500
ORACLE_STARTING_CASH=10000.0
ORACLE_REPLICATES=1
